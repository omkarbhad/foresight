# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/foresight

# LLM — configure via Settings UI or set here
# Supported providers: anthropic, openrouter, openai
LLM_PROVIDER=openrouter
LLM_MODEL=openrouter/auto
LLM_API_KEY=

# Optional — data sources for real-world grounding
NEWS_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=
FINNHUB_API_KEY=

# Optional — graph memory (Neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
GRAPH_MEMORY_ENABLED=false

# Server
FLASK_PORT=5001
FLASK_DEBUG=true
